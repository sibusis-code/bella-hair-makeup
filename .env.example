# Example environment configuration for the Bella Hair & Makeup booking site.
# Copy this file to `.env` and fill in your own values (or set these as
# environment variables in your host's dashboard, e.g. Vercel Project Settings).
# Never commit a real `.env`.

# --- Database (MySQL/MariaDB) ---
# On Vercel (serverless) there is no built-in MySQL: point these at an external
# managed MySQL (Railway, Aiven, PlanetScale-compatible, etc.). Leaving a
# non-resolving host keeps the public marketing pages rendering in offline mode.
DB_HOST=your-db-host.example.com
DB_NAME=bella_hair
DB_USER=demo_db_user
DB_PASS=CHANGE_ME_DB_PASSWORD
DB_CONNECT_TIMEOUT_SECONDS=5
ALLOW_DB_OFFLINE_MODE=true
DB_OFFLINE_GRACE_SECONDS=300

# --- PayFast (SANDBOX public test credentials — safe for a demo) ---
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_SANDBOX=true
PAYFAST_PASSPHRASE=

BOOKING_DEPOSIT_AMOUNT=500.00

# Leave SITE_URL blank to auto-detect the host (works on any domain, incl. *.vercel.app).
SITE_URL=
PAYFAST_NOTIFY_URL_OVERRIDE=

# --- Email ---
EMAIL_FROM_NAME=Bella Hair & Makeup
EMAIL_FROM_ADDRESS=bookings@bellahairandmakeup.co.za
EMAIL_ADMIN_ADDRESS=admin@bellahairandmakeup.co.za
SEND_CLIENT_EMAILS=true
SEND_ADMIN_EMAILS=true
EMAIL_USE_SMTP=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=bookings@bellahairandmakeup.co.za
EMAIL_SMTP_PASS=

# --- Analytics (optional) ---
GA4_MEASUREMENT_ID=

# --- Mobile travel pricing (optional Google Maps keys) ---
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=
TRAVEL_RATE_PER_KM=10
TRAVEL_ROUND_TRIP=true
TRAVEL_ORIGIN_ADDRESS=12 Demo Street, Sandton, Johannesburg, 2196, South Africa
TRAVEL_MAX_KM=0

# --- Maintenance mode ---
MAINTENANCE_MODE=false
MAINTENANCE_BYPASS_KEY=demo-preview-key-change-me
